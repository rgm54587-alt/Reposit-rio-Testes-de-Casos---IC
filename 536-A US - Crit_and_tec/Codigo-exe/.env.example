# Application
BASE_URL=https://example.test
SEARCH_PATH=/

# Search data
AUTOCOMPLETE_TERM=Notebook
AUTOCOMPLETE_EXPECTED_PRODUCT=Notebook Lenovo
FILTER_TERM=Cerveja
FILTER_EXPECTED_PRODUCT=Cerveja Premium
FUZZY_EXPECTED_TERM=Chocolate
FUZZY_EXPECTED_PRODUCT=Chocolate
FUZZY_SPACED_INPUT=Choco late
FUZZY_MISSING_LETTER_INPUT=Choclate
VALID_SEARCH_TERM=Mouse Sem Fio
VALID_EXPECTED_PRODUCT=Mouse Sem Fio
NO_RESULT_TERM=ZXQ987ProdutoInexistente

# Texts / business rules
DID_YOU_MEAN_TEXT=Você quis dizer
NO_RESULTS_TEXT=Nenhum resultado encontrado
INTERNAL_TITLE=ProductAvailability
INTERNAL_TYPE_CODE=40

# Performance: define the approved project limit.
# The default is only a starting point and must be approved by the team.
AUTOCOMPLETE_MAX_MS=500

# Selectors. Prefer stable data-testid attributes in the real application.
SEARCH_INPUT_SELECTOR=[data-testid="search-input"]
SEARCH_BUTTON_SELECTOR=[data-testid="search-button"]
AUTOCOMPLETE_PANEL_SELECTOR=[data-testid="search-autocomplete"]
AUTOCOMPLETE_ITEM_SELECTOR=[data-testid="autocomplete-item"]
SEARCH_RESULTS_CONTAINER_SELECTOR=[data-testid="search-results"]
SEARCH_RESULT_ITEM_SELECTOR=[data-testid="search-result-item"]
NO_RESULTS_SELECTOR=[data-testid="no-search-results"]
DID_YOU_MEAN_SELECTOR=[data-testid="did-you-mean"]

# Optional selector that identifies displayed records with internal type 40.
# Keep the default if the UI exposes this data attribute.
INTERNAL_TYPE_SELECTOR=[data-product-type="40"]
