# Application
BASE_URL=https://example.test
LOGIN_PATH=/
BROWSER=chromium
HEADLESS=true
DEFAULT_TIMEOUT_MS=10000

# Existing active customer
VALID_EMAIL=cliente.teste@example.com
VALID_PASSWORD=SenhaValida@2026
INVALID_PASSWORD=SenhaIncorreta@2026
AUTHENTICATED_MARKER_TEXT=Minha conta
LOGOUT_TEXT=Logout
INVALID_LOGIN_MESSAGE=Login inválido

# Password recovery customer
RECOVERY_EMAIL=cliente.recuperacao@example.com
RECOVERY_OLD_PASSWORD=SenhaAntiga@2026
RECOVERY_NEW_PASSWORD=NovaSenha@2026
RESET_REQUEST_MESSAGE=Solicitação enviada
RESET_SUCCESS_MESSAGE=Senha redefinida
RESET_LINK_EXPIRED_MESSAGE=Link inválido
RESET_EMAIL_SUBJECT=Redefinição de senha
RESET_LINK_PATTERN=/reset-password/

# Approved design tokens from the wireframe/design system.
# Replace these placeholders before running visual tests.
DEFAULT_BG_COLOR=__SET_FROM_WIREFRAME__
DEFAULT_TEXT_COLOR=__SET_FROM_WIREFRAME__
DEFAULT_BORDER_COLOR=__SET_FROM_WIREFRAME__
SELECTED_BG_COLOR=__SET_FROM_WIREFRAME__
SELECTED_TEXT_COLOR=__SET_FROM_WIREFRAME__
VISUAL_TOLERANCE_PX=2

# Mail backend: mailhog or imap
MAIL_BACKEND=mailhog
MAILHOG_BASE_URL=http://localhost:8025
IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_USE_SSL=true
EMAIL_WAIT_SECONDS=30

# Optional selector overrides. Defaults assume data-testid attributes.
SEL_LOGIN_CENTRE_BUTTON=[data-testid='login-centre-button']
SEL_LOGIN_ACCORDION=[data-testid='login-centre-accordion']
SEL_LOGIN_MENU=[data-testid='login-centre-menu']
SEL_ONLINE_SHOP_OPTION=[data-testid='online-shop-option']
SEL_LOGIN_FORM=[data-testid='online-shop-login-form']
SEL_EMAIL_INPUT=[data-testid='login-email']
SEL_PASSWORD_INPUT=[data-testid='login-password']
SEL_LOGIN_BUTTON=[data-testid='login-submit']
SEL_FORGOT_PASSWORD=[data-testid='forgot-password-link']
SEL_LOGIN_MESSAGE=[data-testid='login-message']
SEL_AUTHENTICATED_MARKER=[data-testid='authenticated-marker']
SEL_LOGOUT=[data-testid='logout']
SEL_REFERENCE_SPECIALISED_DATABASES=[data-testid='specialised-databases']
SEL_REFERENCE_INPUTS=[data-testid='specialised-databases'] input
SEL_FORGOT_EMAIL_INPUT=[data-testid='forgot-email']
SEL_FORGOT_SUBMIT=[data-testid='forgot-submit']
SEL_FORGOT_MESSAGE=[data-testid='forgot-message']
SEL_RESET_PASSWORD=[data-testid='reset-password']
