# URL base e rotas reais do sistema
BASE_URL=http://localhost:3000
DETAIL_PATH_TEMPLATE=/products/{product_id}

# Identificadores de títulos do catálogo de testes
TITLE_MAIN_ID=TITULO-001
TITLE_MAIN_NAME=Dom Casmurro
TITLE_MAIN_AUTHOR=Machado de Assis
TITLE_MAIN_COVER_TOKEN=dom-casmurro
TITLE_OTHER_ID=TITULO-002
TITLE_OTHER_NAME=Memórias Póstumas de Brás Cubas
TITLE_OTHER_COVER_TOKEN=memorias-postumas
TITLE_THIRD_ID=TITULO-003
TITLE_THIRD_NAME=Grande Sertão: Veredas

# Produtos com quantidades diferentes de linhas bibliográficas
TITLE_FEW_BIB_ID=TITULO-RESUMIDO
TITLE_MANY_BIB_ID=TITULO-COMPLETO
EXPECTED_FEW_BIB_LINES=3
EXPECTED_MANY_BIB_LINES=12

# Seletores da aplicação. Prefira data-testid estáveis.
DETAIL_CONTAINER_SELECTOR=[data-testid="product-detail"]
TITLE_SELECTOR=[data-testid="product-title"]
AUTHOR_SELECTOR=[data-testid="product-author"]
COVER_SELECTOR=[data-testid="product-cover"] img
BIBLIOGRAPHIC_ROW_SELECTOR=[data-testid="bibliographic-row"]

# Referência visual aprovada para a viewport abaixo
VIEWPORT_WIDTH=1440
VIEWPORT_HEIGHT=1000
EXPECTED_COVER_WIDTH_PX=240
EXPECTED_COVER_HEIGHT_PX=360
EXPECTED_COVER_X_RELATIVE_PX=48
EXPECTED_COVER_Y_RELATIVE_PX=40
GEOMETRY_TOLERANCE_PX=3
ASPECT_RATIO_TOLERANCE=0.02
MAX_LAYOUT_SHIFT_PX=3
LAYOUT_MONITOR_MS=2500

# Otimização de imagem
MAX_IMAGE_SCALE_FACTOR=2.0
MIN_IMAGE_SCALE_FACTOR=1.0
MAX_IMAGE_BYTES=350000
ALLOWED_IMAGE_FORMATS=webp,avif,jpeg,jpg,png

# Cache: "permanente" deve ser convertido em política mensurável.
# Exemplo: 31536000 = 1 ano. Use o valor oficialmente aprovado.
MIN_CACHE_MAX_AGE_SECONDS=31536000
REQUIRE_IMMUTABLE_CACHE=true
REQUIRE_VERSIONED_IMAGE_URL=true

# Acessibilidade
REQUIRE_COVER_ALT_TEXT=true

# Execução
HEADLESS=true
